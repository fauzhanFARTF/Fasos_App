# Copy file ini ke .env dan isi nilainya

# Database
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Security
SECRET_KEY=change-me-in-production
DEBUG=True

# CORS Origins (pisahkan dengan koma, tanpa spasi)
# Contoh: http://localhost:5173,https://app.domain.com
CORS_ORIGINS=http://localhost:5173